{
  "//": "@wrst/cli is a Node program (not a wrst app), so it has its own config: Node types + ES2020 lib.",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noEmit": true,
    "rootDir": "src"
  },
  "include": ["src"]
}
